FROM node:22-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    jq \
    gh \
    podman \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g @anthropic-ai/claude-code

# Bake default configs (skills, etc.) into the image
# Structure mirrors ~/.claude/ -- entrypoint symlinks top-level children
COPY common_dotfiles/agent-skills /usr/local/share/config/claude-code/skills

# Entrypoint: symlinks baked-in defaults into persistent home, then exec's CMD
COPY scripts/claude-code-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

COPY --from=ghcr.io/astral-sh/uv:0.11.29 /uv /uvx /bin
ENV PATH="/root/.local/bin:${PATH}"
RUN uv tool install graphifyy && \
    graphify install && \
    mv /root/.claude/skills/graphify /usr/local/share/config/claude-code/skills/graphify && \
    claude plugin marketplace add DietrichGebert/ponytail && \
    claude plugin install ponytail@ponytail

WORKDIR /workspace
ENTRYPOINT ["/entrypoint.sh"]
CMD ["claude"]
