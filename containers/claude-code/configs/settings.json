{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git remote -v)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(glab issue view*)",
      "Bash(glab issue list*)",
      "Bash(ls*)",
      "Edit(/tmp/**)",
      "Read(~/.claude/skills/**)",
      "Read(~/.claude/settings.json)",
      "Read(/usr/local/share/config/claude-code/skills)"
    ],
    "deny": [
      "Read(~/.config/gh/**)",
      "Read(~/.config/glab-cli/**)",
      "Read(~/.claude/.credentials.json)",
      "Grep(~/.config/gh/**)",
      "Grep(~/.config/glab-cli/**)",
      "Grep(~/.claude/.credentials.json)"
    ]
  }
}
